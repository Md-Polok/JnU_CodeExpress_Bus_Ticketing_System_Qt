      <property name="styleSheet">
       <string notr="true">/* Base Window background */
QMainWindow, QWidget {
    background-color: #f5f6f8;
    color: #333333; /* Dark gray text */
}

/* Individual Buttons */
QPushButton {
    background-color: #1e3d59; /* Deep executive blue */
    color: white;
    border-radius: 4px;
    padding: 6px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #17b890; /* Turns teal when hovered */
}

/* Tables */
QTableWidget {
    background-color: #ffffff;
    gridline-color: #e0e0e0;
    color: #333333;
}
QHeaderView::section {
    background-color: #1e3d59;
    color: white;
    font-weight: bold;
}

/* Dropdown Boxes */
QComboBox {
    background-color: #ffffff;
    border: 1px solid #ccc;
    padding: 4px;
}

QTabBar::tab {
    color: #1f2937; /* Forces text to always be a clear, dark charcoal color */
    background-color: #f3f4f6; /* Light gray background for unselected tabs */
    padding: 6px 12px;
}
QTabBar::tab:selected {
    background-color: #374151; /* Keeps your dark gray active tab */
    color: white; /* White text for the active tab */
}</string>
      </property>
